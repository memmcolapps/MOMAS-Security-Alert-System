# Frontend configuration — consumed by scripts/build-config.js at build time.
# Copy to .env and fill in, then run `npm run build` to generate config.js.
# On Vercel, set these as Project Environment Variables (no .env file needed).

# Backend API base URL. Leave empty for same-origin (e.g. local dev against
# a backend serving the frontend statically).
MOMAS_API_BASE=http://localhost:5050

# How often the dashboard refetches incidents (ms).
MOMAS_REFRESH_MS=300000

# Max markers rendered on the map at once.
MOMAS_MAX_MARKERS=500
