# MOMAS backend runtime configuration — Pattern B.
#
# Install on the VPS at:    /etc/momas/momas.env
# Owner:                    deploy:deploy
# Permissions:              600
#
# Loaded by /etc/systemd/system/momas-backend.service via EnvironmentFile=.
# Edit values here, then:   sudo systemctl restart momas-backend
#
# This file is NEVER touched by the GitHub Actions deploy workflow.

# ── Database (REQUIRED) ────────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# ── Server ─────────────────────────────────────────────────────────────
PORT=3000

# ── Auth (REQUIRED) ────────────────────────────────────────────────────
# Generate with: openssl rand -hex 48
AUTH_JWT_SECRET=replace-me-with-a-long-random-string

# Optional bootstrap admin (created once on first boot if no admin exists)
# EPAIL_ADMIN_EMAIL=admin@example.com
# EPAIL_ADMIN_PASSWORD=initial-temporary-password

# ── Background scrape jobs ─────────────────────────────────────────────
START_SCRAPE_JOBS=true
SCRAPE_HOT_SEC=90
SCRAPE_WARM_SEC=300
SCRAPE_COLD_MIN=30

# ── Frontend config (returned by /api/config) ──────────────────────────
FRONTEND_API_BASE=
FRONTEND_REFRESH_MS=1800000
FRONTEND_MAX_MARKERS=500

# ── Classifier (Groq, free tier) ───────────────────────────────────────
GROQ_API_KEY=replace-me
# Triage model (per-model free-tier quota: 30 RPM / 30K TPM)
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Second-opinion model for positives — separate quota bucket from triage
# GROQ_VERIFY_MODEL=llama-3.3-70b-versatile
# GROQ_VERIFY_ENABLED=true
# GROQ_MIN_INTERVAL_MS=3000
# Reject incidents whose event date predates publication by more than N days
# CLASSIFIER_MAX_EVENT_AGE_DAYS=3

# ── Telegram real-time listener (MTProto via GramJS, free) ─────────────
# 1. api_id/api_hash: https://my.telegram.org → API development tools
# 2. Session string:  bun run scripts/telegram-login.ts (run locally once)
# 3. Channels: public @handles without the @, comma-separated
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_SESSION=
# TELEGRAM_MTPROTO_CHANNELS=zagazolamakama,PeoplesGazette,thecableng
# TELEGRAM_MTPROTO_BACKFILL=20

# ── POCSTARS radios ────────────────────────────────────────────────────
POCSTARS_LOC_BASE=http://102.221.238.124:9275
POCSTARS_SOS_BASE=http://102.221.238.124:6891
POCSTARS_TARGET_UID=583

# ── Drone tracking (raw MAVLink TCP listener) ──────────────────────────
MAVLINK_ENABLE=true
MAVLINK_TCP_HOST=0.0.0.0
MAVLINK_TCP_PORT=5760
DRONE_STALE_SEC=30
DRONE_FORGET_SEC=3600
