# Server
PORT=3000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Create the DB first: createdb nigeria_security
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/nigeria_security

# Scraper settings
START_SCRAPE_JOBS=true
SCRAPE_HOT_SEC=90
SCRAPE_WARM_SEC=300
SCRAPE_COLD_MIN=30

# POCSTARS device/SOS proxy
POCSTARS_LOC_BASE=http://102.221.238.124:9275
POCSTARS_SOS_BASE=http://102.221.238.124:6891
POCSTARS_TARGET_UID=583

# HAPI (Humanitarian API) settings (https://hapi.humdata.org)
HAPI_ENABLED=true
HAPI_APP_NAME=momas-security-alert
HAPI_APP_EMAIL=user@example.com

# ReliefWeb API settings (https://apidoc.reliefweb.int/)
RELIEFWEB_ENABLED=true
RELIEFWEB_APPNAME=momas-security-alert

# GDELT 2.0 DOC API settings (https://blog.gdeltproject.org/gdelt-doc-2-0-api-debuts/)
GDELT_ENABLED=true

# Groq (LLM classifier) — OpenAI-compatible API for incident classification.
# Pipeline: regex prefilter → sha1 LRU cache → Groq batch call (JSON array).
# If GROQ_API_KEY is unset, items that pass the prefilter are dropped (null).
GROQ_API_KEY=

# Model choice. llama-3.1-8b-instant is the free-tier sweet spot:
#   - 14.4K requests/day (vs 1K for gpt-oss / llama-70b / scout / qwen3)
#   - 500K tokens/day
#   - Good enough for fixed-schema JSON classification at temperature=0
# Upgrade to meta-llama/llama-4-scout-17b-16e-instruct or qwen/qwen3-32b
# if you need better quality and can live with 1K RPD.
GROQ_MODEL=llama-3.1-8b-instant

# Rate-limit spacing. llama-3.1-8b-instant has a tight 6K TPM cap.
# Each batch ≈ 1–1.5K tokens, so 15000ms (4 calls/min) keeps us safely under.
# Raise for larger models with higher TPM (scout: 30K, qwen3: 6K, 70b: 12K).
GROQ_MIN_INTERVAL_MS=15000

# Items per Groq call. Higher = fewer requests, more tokens per call.
GROQ_BATCH_SIZE=10

# In-memory LRU cache size for classified (title+description) hashes.
CLASSIFIER_CACHE_MAX=5000

GROQ_TIMEOUT_MS=30000

# RSS feeds fetched in parallel.
RSS_FEED_CONCURRENCY=5
